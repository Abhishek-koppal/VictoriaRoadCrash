{
  "datasets": [
    {
      "name": "a2421752",
      "displayName": "Victoria Map",
      "queryLines": [
        "select LONGITUDE, LATITUDE, ACCIDENT_TYPE, ACCIDENT_TIME from roadcrashvic"
      ],
      "catalog": "victoria_road_crash",
      "schema": "default"
    },
    {
      "name": "65b77d86",
      "displayName": "Top 10 accident zones",
      "queryLines": [
        "select LGA_NAME, count(*) as accident_count\n",
        "from roadcrashvic\n",
        "group by LGA_NAME\n",
        "order by accident_count desc\n",
        "limit 10"
      ],
      "catalog": "victoria_road_crash",
      "schema": "default"
    },
    {
      "name": "e95c70ac",
      "displayName": "Total accident",
      "queryLines": [
        "SELECT\n",
        "  YEAR(ACCIDENT_DATE) AS year,\n",
        "  COUNT(*) AS total_accidents\n",
        "FROM\n",
        "  roadcrashvic\n",
        "GROUP BY\n",
        "  YEAR(ACCIDENT_DATE)\n",
        "ORDER BY\n",
        "  year ASC"
      ],
      "catalog": "victoria_road_crash",
      "schema": "default"
    },
    {
      "name": "ff9e0cd4",
      "displayName": "Crash Incident Clusters By Road With Geo Coordinates",
      "queryLines": [
        "-- Find crash hotspots by road, with coordinates for heat map plotting\n",
        "SELECT\n",
        "  road_name,\n",
        "  latitude,\n",
        "  longitude,\n",
        "  COUNT(*) AS crash_count\n",
        "FROM\n",
        "  roadcrashvic\n",
        "WHERE\n",
        "  latitude IS NOT NULL\n",
        "  AND longitude IS NOT NULL\n",
        "GROUP BY\n",
        "  road_name,\n",
        "  latitude,\n",
        "  longitude\n",
        "ORDER BY\n",
        "  crash_count DESC\n",
        "LIMIT 100"
      ],
      "catalog": "victoria_road_crash",
      "schema": "default"
    },
    {
      "name": "469a967b",
      "displayName": "Serious Injury Accidents by Suburb on Streets",
      "queryLines": [
        "\n",
        "SELECT\n",
        "  LGA_NAME AS suburb,\n",
        "  SEVERITY,\n",
        "  COUNT(*) AS accident_count\n",
        "FROM\n",
        "  roadcrashvic\n",
        "WHERE\n",
        "  LGA_NAME IS NOT NULL and \n",
        "  SEVERITY  = 'Serious injury accident' and ROAD_TYPE = 'STREET'\n",
        "GROUP BY\n",
        "  LGA_NAME,\n",
        "  SEVERITY\n",
        "ORDER BY\n",
        "  accident_count DESC\n",
        "LIMIT 10"
      ],
      "catalog": "victoria_road_crash",
      "schema": "default"
    },
    {
      "name": "b4985fbf",
      "displayName": "road crash victorian data summary count",
      "queryLines": [
        "select * from roadcrashvic"
      ],
      "catalog": "victoria_road_crash",
      "schema": "default"
    },
    {
      "name": "309d0d43",
      "displayName": "Road Crash Frequency by hour",
      "queryLines": [
        "select hour(ACCIDENT_TIME) as accident_hour, count(*) as crashes\n",
        "from roadcrashvic\n",
        "where ACCIDENT_TIME is not null\n",
        "group by hour(ACCIDENT_TIME)\n",
        "order by crashes desc\n"
      ],
      "catalog": "victoria_road_crash",
      "schema": "default"
    },
    {
      "name": "96c8dd47",
      "displayName": "Top Ten Local Areas by Road Fatality Rate",
      "queryLines": [
        "SELECT\n",
        "  location,\n",
        "  fatal_count,\n",
        "  total_count,\n",
        "  fatality_rate\n",
        "FROM (\n",
        "  SELECT\n",
        "    LGA_NAME AS location,\n",
        "    SUM(FATALITY) AS fatal_count,\n",
        "    COUNT(*) AS total_count,\n",
        "    (SUM(FATALITY) / COUNT(*)) AS fatality_rate,\n",
        "    RANK() OVER (ORDER BY (SUM(FATALITY) / COUNT(*)) DESC) AS rnk\n",
        "  FROM roadcrashvic\n",
        "  GROUP BY LGA_NAME\n",
        ")\n",
        "WHERE rnk BETWEEN 2 AND 11\n",
        "ORDER BY fatality_rate DESC"
      ],
      "catalog": "victoria_road_crash",
      "schema": "default"
    }
  ],
